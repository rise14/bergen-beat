# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.

# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only, never expose to browser

# ─── Resend (transactional email) ───────────────────────────────────────────
RESEND_API_KEY=re_your_key_here

# ─── Mapbox ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_token_here

# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000          # change to https://www.bergenbeat.net in production
ADMIN_EMAIL=admin@bergenbeat.net                    # email address allowed to log into /admin

# ─── Analytics ──────────────────────────────────────────────────────────────
# Google Analytics 4 — leave blank to disable (safe for local dev)
# Find your Measurement ID in GA4: Admin → Data Streams → your stream → Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── External event APIs (optional — needed for /admin/import) ───────────────
# Ticketmaster: create a free app at https://developer.ticketmaster.com — copy the Consumer Key
TICKETMASTER_API_KEY=your_ticketmaster_consumer_key

# PredictHQ: generate a token at https://control.predicthq.com/tokens
PREDICTHQ_ACCESS_TOKEN=your_predicthq_access_token

# Unsplash (optional): fills in banner images for events that don't have one
# Register a free app at https://unsplash.com/developers → copy the Access Key
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# ─── Cron job secret ────────────────────────────────────────────────────────
# A random string used to secure the /api/cron/import endpoint.
# Generate one with: openssl rand -base64 32
# Add the same value to Vercel environment variables.
CRON_SECRET=your_random_secret_here
