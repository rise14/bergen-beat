# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.

# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only, never expose to browser

# ─── Resend (transactional email) ───────────────────────────────────────────
RESEND_API_KEY=re_your_key_here

# ─── Mapbox ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_token_here

# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000          # change to https://www.bergenbeat.net in production
ADMIN_EMAIL=admin@bergenbeat.net                    # email address allowed to log into /admin

# ─── Social auto-posting ────────────────────────────────────────────────────
# Set to a Make or Zapier webhook URL to auto-post approved events to social media
# Leave blank to disable. The webhook receives a JSON payload with event details.
SOCIAL_WEBHOOK_URL=

# ─── Analytics ──────────────────────────────────────────────────────────────
# Google Tag Manager — leave blank to disable (safe for local dev)
# Create a container at tagmanager.google.com — copy the GTM-XXXXXXX container ID
# Then add a GA4 Configuration tag inside GTM pointing at your GA4 Measurement ID
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ─── External event APIs (optional — needed for /admin/import) ───────────────
# Ticketmaster: create a free app at https://developer.ticketmaster.com — copy the Consumer Key
TICKETMASTER_API_KEY=your_ticketmaster_consumer_key

# PredictHQ: generate a token at https://control.predicthq.com/tokens
PREDICTHQ_ACCESS_TOKEN=your_predicthq_access_token

# Unsplash (optional): fills in banner images for events that don't have one
# Register a free app at https://unsplash.com/developers → copy the Access Key
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# ─── Cron job secret ────────────────────────────────────────────────────────
# A random string used to secure the /api/cron/import endpoint.
# Generate one with: openssl rand -base64 32
# Add the same value to Vercel environment variables.
CRON_SECRET=your_random_secret_here
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ─── Stripe (sponsored listings) ────────────────────────────────────────────
# Create a free account at https://stripe.com
# Test keys: Stripe Dashboard → Developers → API keys
# Live keys: same place, toggle "Live mode"
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# Webhook endpoint to register in Stripe Dashboard:
#   https://www.bergenbeat.net/api/stripe/webhook
#   Events to listen for: checkout.session.completed
